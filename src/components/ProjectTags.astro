---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div>
  {tags.map((tag) => <span>{tag}</span>)}
</div>

<style>
  div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
  }

  span {
    font-size: 80%;
    color: var(--color-text-dimmed);
    background-color: var(--color-surface);
    border-radius: 16px;
    padding: 0.1em 0.6em;
  }
</style>
