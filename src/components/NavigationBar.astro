---
const path = Astro.url.pathname;
---

<nav>
  <div id="container" class="limit-width">
    <div id="desktop-left">
      <ul id="desktop-links" class="links">
        <li class="brand">
          <a href="/" class={path === "/" ? "active" : ""}>MastarCheeze</a>
        </li>
        <li>
          <a href="/projects" class={path === "/projects" ? "active" : ""}>Projects</a>
        </li>
        <li>
          <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}>Blog</a>
        </li>
      </ul>
    </div>
    <div id="mobile-left">
      <button id="mobile-menu-open">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
    <div id="right">
      <ul id="socials">
        <li>
          <a href="https://github.com/MastarCheeze"><i class="fa-brands fa-github"></i></a>
        </li>
        <li>
          <a href="https://discord.com/users/413865847308812299"><i class="fa-brands fa-discord"></i></a>
        </li>
        <li>
          <a href="mailto:mastarcheeze@gmail.com"><i class="fa-solid fa-envelope"></i></a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div id="mobile-menu" class="mobile-menu-hide">
  <button id="mobile-menu-close"><i class="fa-solid fa-xmark"></i></button>
  <ul id="mobile-menu-links" class="links">
    <li class="brand">
      <a href="/" class={path === "/" ? "active" : ""}>MastarCheeze</a>
    </li>
    <li>
      <a href="/projects" class={path === "/projects" ? "active" : ""}>Projects</a>
    </li>
    <li>
      <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}>Blog</a>
    </li>
  </ul>
</div>

<div id="bg-tint" class="bg-tint-hide"></div>

<script>
  const open = document.querySelector("#mobile-menu-open") as HTMLElement;
  const close = document.querySelector("#mobile-menu-close") as HTMLElement;
  const menu = document.querySelector("#mobile-menu") as HTMLElement;
  const bgTint = document.querySelector("#bg-tint") as HTMLElement;

  open.addEventListener("click", (e) => {
    menu.className = "mobile-menu-show";
    bgTint.className = "bg-tint-show";
  });

  close.addEventListener("click", (e) => {
    menu.className = "mobile-menu-hide";
    bgTint.className = "bg-tint-hide";
  });

  bgTint.addEventListener("click", (e) => {
    menu.className = "mobile-menu-hide";
    bgTint.className = "bg-tint-hide";
  });
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background-color: var(--color-bg);
    padding-block: 1em;
    border-bottom: 1px solid var(--color-border);
  }

  ul {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #desktop-links {
    align-items: end;
  }

  .brand {
    font-size: 1.5rem;
    font-weight: bold;
  }

  .links {
    font-size: 1.25rem;
  }

  .links a {
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    transition: color 0.3s ease;
  }

  .links a::before {
    content: "";
    position: absolute;
    z-index: -1;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background-color: var(--color-primary-light);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.1s ease;
  }

  .links a.active {
    color: var(--color-primary);
  }

  .links a.active:hover {
    color: var(--color-primary);
  }

  .links a.active::before {
    background-color: var(--color-primary);
    transform: scaleX(1);
  }

  .links a:hover {
    color: var(--color-primary-light);
    text-decoration: none;
  }

  .links a:hover::before {
    transform: scaleX(1);
  }

  #desktop-left {
    display: flex;
    gap: 2em;
  }

  #desktop-links {
    gap: 1em;
  }

  #mobile-left {
    display: none;
  }

  #socials {
    font-size: 1.75rem;
    gap: 0.5em;
  }

  #socials i {
    width: max-content;
    color: var(--color-text);
    transition:
      transform 0.1s ease,
      color 0.3s ease;
  }

  #socials i:hover {
    color: var(--color-primary-light);
    transform: scale(1.1);
  }

  #mobile-menu {
    display: none;
  }

  #bg-tint {
    display: none;
  }

  @media (width < 48rem) {
    #desktop-left {
      display: none;
    }

    #mobile-left {
      display: block;
      font-size: 1.75rem;
    }

    #mobile-menu {
      display: flex;
      flex-direction: column;
      align-items: start;
      position: fixed;
      z-index: 1002;
      background-color: var(--color-bg);
      top: 0;
      bottom: 0;
      left: 0;
      padding: 1em 4em 1em 2em;
      border-right: 1px solid var(--color-border);
      transition: transform 0.3s ease;
    }

    .mobile-menu-hide {
      transform: translateX(-100%);
    }

    .mobile-menu-show {
      transform: translateX(0);
    }

    #mobile-menu-close {
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }

    #mobile-menu-links {
      flex-direction: column;
      margin-top: 1rem;
      gap: 0.5rem;
    }

    #bg-tint {
      display: block;
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 1001;
      background-color: black;
      transition: opacity 0.3s ease;
    }

    .bg-tint-hide {
      pointer-events: none;
      opacity: 0;
    }

    .bg-tint-show {
      pointer-events: auto;
      opacity: 0.6;
    }
  }
</style>
